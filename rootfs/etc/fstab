# Btrfs subvolumes 
UUID=ROOTUUID   /   btrfs   rw,noatime,compress=zstd:3,ssd,space_cache=v2,discard=async,subvol=@    0 0

UUID=ROOTUUID   /home   btrfs   nosuid,nodev,rw,noatime,compress=zstd:3,ssd,space_cache=v2,discard=async,subvol=@home   0 0

UUID=ROOTUUID   /var    btrfs   nosuid,nodev,rw,noatime,compress=zstd:3,ssd,space_cache=v2,discard=async,subvol=@var    0 0

# Boot partition
# GID: 998 is wheel group
UUID=BOOTUUID  /boot   vfat    rw,noatime,fmask=0137,dmask=0027,uid=0,gid=998,codepage=437,iocharset=ascii,shortname=mixed,utf8,errors=remount-ro  0 2

# pacman packages cache
# tmpfs /var/cache/pacman/pkg tmpfs rw,size=4G,nr_inodes=400k,mode=0755 0 0

# Share
/srv/share  /srv/share  none    bind,rw,nosuid,nodev,nofail     0   0

