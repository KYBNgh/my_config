#!/usr/bin/env bash

count=0;
max_retries=10;

if (($# == 0)); then
    # Don't do anything, show help
    ssh;
    exit 0;
fi

until ssh "$@"; do
    exit_code=$?;

    if ((count >= max_retries)); then 
        printf "\n"
        printf "%s\n" "sc: limit out($max_retries times)";
        break;
    fi

    ((count++));

    printf "\n";
    printf "%s\n" "sc: ssh exited with $exit";
    printf "%s\n" "sc: retry in 3 sec ($count/$max_retries)";
    printf "%s" "sc: press return to retry immediately";

    read -r -t 3 dummy;

    printf "%s\n" "sc: reconnecting...";
    printf "\n"

done

# If "$exit_code" is empty, just "exit"
exit $exit_code;
